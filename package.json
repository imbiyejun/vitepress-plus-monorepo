{
  "name": "vitepress-plus-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "VitePress Plus - 增强版 VitePress 文档系统",
  "scripts": {
    "dev": "pnpm --filter @imbiyejun/vitepress-plus dev",
    "dev:admin": "pnpm --filter @imbiyejun/vitepress-admin dev",
    "dev:example": "pnpm --filter example-docs dev",
    "build": "pnpm -r --filter \"./packages/**\" build",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,scss,md}\"",
    "type-check": "pnpm -r --filter \"./packages/**\" type-check",
    "type-check:staged": "node scripts/type-check-staged.mjs",
    "prepare": "husky",
    "release": "tsx scripts/release.ts",
    "release:rc": "tsx scripts/release.ts --type rc",
    "release:rc:next": "tsx scripts/release.ts --type rc --bump next",
    "release:rc:patch": "tsx scripts/release.ts --type rc --bump patch",
    "release:rc:minor": "tsx scripts/release.ts --type rc --bump minor",
    "release:rc:major": "tsx scripts/release.ts --type rc --bump major",
    "release:prod": "tsx scripts/release.ts --type release",
    "release:prod:patch": "tsx scripts/release.ts --type release --bump patch",
    "release:prod:minor": "tsx scripts/release.ts --type release --bump minor",
    "release:prod:major": "tsx scripts/release.ts --type release --bump major",
    "release:dry": "tsx scripts/release.ts --dry"
  },
  "keywords": [
    "vitepress",
    "documentation",
    "knowledge-management"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@8.15.4",
  "pnpm": {
    "overrides": {
      "@imbiyejun/vitepress-admin": "workspace:*"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.8",
    "enquirer": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "picocolors": "^1.1.1",
    "prettier": "^3.2.5",
    "semver": "^7.6.3",
    "tsx": "^4.20.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.48.1",
    "vue-eslint-parser": "^10.2.0"
  }
}
