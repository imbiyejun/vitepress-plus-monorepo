# Server Configuration
PORT=3000

# Local Storage Configuration
# Path relative to project root where images will be stored
LOCAL_STORAGE_PATH=public/images

# Qiniu CDN Configuration (Optional)
# If configured, images can be uploaded to Qiniu Cloud Storage
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=your_cdn_domain

# Private Server Deploy Configuration (Optional)
# SSH/SFTP configuration for deploying to private nginx server
DEPLOY_HOST=your_server_ip
DEPLOY_PORT=22
DEPLOY_USERNAME=your_username
DEPLOY_PASSWORD=your_password
DEPLOY_REMOTE_PATH=/var/www/html
DEPLOY_DOMAIN=example.com # 可选，如果配置了域名，则使用域名访问，否则使用IP访问

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root123456

# AI Chat Configuration (Optional)
# Configure one or more providers below. Only providers with API keys will be available.
# You can switch between configured providers in the Chat UI.

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen (通义千问)
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Kimi (Moonshot)
KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
